<?xml version="1.0" encoding="utf-8"?>
<!--
  Local development: resolves sibling KoreForge packages from their build artifacts
  before falling back to nuget.org.  To build all local deps first, run:
    bin\build-deps.ps1
-->
<configuration>
  <packageSources>
    <add key="KoreForge.Time.local"       value="../KoreForge.Time/artifacts" />
    <add key="KoreForge.Metrics.local"    value="../KoreForge.Metrics/artifacts" />
    <add key="KoreForge.Logging.local"    value="../KoreForge.Logging/artifacts" />
    <add key="KoreForge.Processing.local" value="../KoreForge.Processing/artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
